# ── Director (OpenAI) — multi-agent ──────────────────────────────
DIRECTOR_PROVIDER=openai
# Brain coordinates intent + briefs (smart model)
DIRECTOR_BRAIN_MODEL=gpt-5.5
# Arms run in parallel: structure / layout / copy / motion / images
DIRECTOR_ARM_MODEL=gpt-4o
# Set to 0 to disable arms — brain alone builds the full MotionProject
DIRECTOR_ARMS_ENABLED=0
# Legacy alias / brain fallback
DIRECTOR_MODEL=gpt-5.5
OPENAI_API_KEY=
# Repair attempts after merge (default 2, max 3)
# DIRECTOR_MAX_ATTEMPTS=2

# Optional alternative Director
ANTHROPIC_API_KEY=

# ── FFmpeg — required for motion render ──────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── ElevenLabs — optional narration ──────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── FLUX / BFL — optional, not in active pipeline ────────────────
BFL_API_KEY=
BFL_API_BASE_URL=https://api.bfl.ai
FLUX_MODEL=flux-pro-1.1

# ── Veo / Gemini — DISABLED in active pipeline (kept for future) ─
GEMINI_API_KEY=
VEO_MODEL=veo-3.1-generate-preview

# ── Export target ────────────────────────────────────────────────
# The server Playwright drives to screenshot /render/[jobId]. Must be the
# `next start` server, never `next dev` — see README. Defaults to port 3000.
# KINETTA_BASE_URL=http://127.0.0.1:3000

# ── Dev: skip OpenAI and use fixture project ─────────────────────
# KINETTA_USE_FIXTURE=1
