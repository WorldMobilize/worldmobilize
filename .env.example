# ── Gemini API (Veo) — video generation ──────────────────────────
GEMINI_API_KEY=
VEO_MODEL=veo-3.1-generate-preview

# ── Black Forest Labs (FLUX) — image generation ──────────────────
BFL_API_KEY=
BFL_API_BASE_URL=https://api.bfl.ai
FLUX_MODEL=flux-pro-1.1

# ── ElevenLabs — narration / voice ───────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── FFmpeg — final composition (local / free) ────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── Director — OpenAI GPT as creative director ───────────────────
# anthropic | openai
DIRECTOR_PROVIDER=openai
DIRECTOR_MODEL=gpt-5.5

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
